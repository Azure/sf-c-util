<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear />
        <add key="MSAzure" value="https://msazure.pkgs.visualstudio.com/One/_packaging/Azure-MessagingStore-Feed/nuget/v3/index.json" />
    </packageSources>
</configuration>

<!-- Default feed for an sf-c-util build. The Azure-MessagingStore-Feed
     is configured with the SF team's ServiceFabric feed as an
     upstream source, so the ServiceFabric.NativeLibsHeaders.retail[.win-arm64]
     packages this repo depends on resolve transparently through it.
     This feed is the only one this repo references, by policy.

     When sf-c-util is consumed as a submodule of a parent project that
     has its own nuget.config, the parent's wins -
     deps/servicefabric/CMakeLists.txt prefers ${CMAKE_SOURCE_DIR}/nuget.config
     over this file. -->
